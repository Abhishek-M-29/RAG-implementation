{
  "__inputs": [],
  "__requires": [],
  "dashboard": {
    "title": "RAG Framework — Observability",
    "tags": ["ragframework", "opentelemetry"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "rate(rag_request_total[5m])",
            "legendFormat": "{{stage}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "rps",
            "min": 0
          }
        }
      },
      {
        "id": 2,
        "title": "Latency (p50 / p95 / p99) by Stage",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(rag_latency_seconds_bucket[5m])) by (le, stage))",
            "legendFormat": "p50 {{stage}}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(rag_latency_seconds_bucket[5m])) by (le, stage))",
            "legendFormat": "p95 {{stage}}",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(rag_latency_seconds_bucket[5m])) by (le, stage))",
            "legendFormat": "p99 {{stage}}",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 3,
        "title": "Cache Hit Rate",
        "type": "stat",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(rag_cache_hit_total[5m])) / (sum(rate(rag_cache_hit_total[5m])) + sum(rate(rag_cache_miss_total[5m]))) * 100",
            "legendFormat": "Hit rate",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 50 },
                { "color": "green", "value": 80 }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Token Throughput",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "rate(rag_tokens_total[5m])",
            "legendFormat": "{{direction}} — {{model}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "tokens"
          }
        }
      },
      {
        "id": 5,
        "title": "Ingestion Queue Depth",
        "type": "stat",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "rag_ingestion_queue_depth",
            "legendFormat": "Queue depth",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 10 },
                { "color": "red", "value": 50 }
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Error Rate by Stage",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "rate(rag_errors_total[5m])",
            "legendFormat": "{{stage}} ({{error.type}})",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "eps",
            "min": 0
          }
        }
      }
    ],
    "refresh": "30s",
    "time": {
      "from": "now-15m",
      "to": "now"
    }
  }
}
